<view class="{{['page', 'data-v-e422322e', virtualHostClass]}}" style="{{virtualHostStyle}}" hidden="{{virtualHostHidden || false}}" id="{{m}}"><view class="header data-v-e422322e"><text class="header-title data-v-e422322e">结算对账</text></view><view class="month-selector data-v-e422322e"><view class="month-arrow touch-target data-v-e422322e" bindtap="{{a}}"><text class="arrow-text data-v-e422322e">&lt;</text></view><text class="month-label data-v-e422322e">{{b}}年{{c}}月</text><view class="month-arrow touch-target data-v-e422322e" bindtap="{{d}}"><text class="arrow-text data-v-e422322e">&gt;</text></view></view><view class="summary-row data-v-e422322e"><view class="summary-card card data-v-e422322e"><text class="summary-label data-v-e422322e">本月销售额</text><text class="summary-value amount-green data-v-e422322e">¥{{e}}</text></view><view class="summary-card card data-v-e422322e"><text class="summary-label data-v-e422322e">平台服务费</text><text class="summary-value data-v-e422322e" style="color:#CA8A04">¥{{f}}</text></view><view class="summary-card card summary-full data-v-e422322e"><text class="summary-label data-v-e422322e">实际到账</text><text class="summary-value data-v-e422322e" style="color:#14532D">¥{{g}}</text><text class="summary-sub data-v-e422322e">共 {{h}} 笔结算</text></view></view><view wx:if="{{i}}" class="loading-box data-v-e422322e"><text class="loading-text data-v-e422322e">加载中...</text></view><view wx:if="{{j}}" class="list data-v-e422322e"><view wx:for="{{k}}" wx:for-item="item" wx:key="k" class="settlement-card card data-v-e422322e"><view class="settlement-top data-v-e422322e"><view class="trade-info data-v-e422322e"><text class="trade-name data-v-e422322e">{{item.a}}</text><text class="trade-date data-v-e422322e">{{item.b}}</text></view><view class="{{['status-badge', 'data-v-e422322e', item.d]}}"><text class="data-v-e422322e">{{item.c}}</text></view></view><view class="total-row data-v-e422322e"><text class="total-label data-v-e422322e">销售总额</text><text class="total-value amount-green data-v-e422322e">¥{{item.e}}</text></view><view class="breakdown data-v-e422322e"><view class="breakdown-item data-v-e422322e"><text class="breakdown-label data-v-e422322e">平台服务费</text><text class="breakdown-value data-v-e422322e">-¥{{item.f}}</text></view><view class="breakdown-item data-v-e422322e"><text class="breakdown-label data-v-e422322e">物流费</text><text class="breakdown-value data-v-e422322e">-¥{{item.g}}</text></view><view class="breakdown-item data-v-e422322e"><text class="breakdown-label data-v-e422322e">损耗扣除</text><text class="breakdown-value data-v-e422322e">-¥{{item.h}}</text></view><view class="breakdown-item data-v-e422322e"><text class="breakdown-label data-v-e422322e">档口佣金</text><text class="breakdown-value data-v-e422322e">-¥{{item.i}}</text></view><view class="breakdown-item highlight data-v-e422322e"><text class="breakdown-label data-v-e422322e">农户实收</text><text class="breakdown-value amount-green data-v-e422322e">¥{{item.j}}</text></view></view></view></view><view wx:if="{{l}}" class="card empty-box data-v-e422322e"><text class="empty-text data-v-e422322e">暂无结算记录</text></view></view>