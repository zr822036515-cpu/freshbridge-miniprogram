<view class="{{['page', 'data-v-f6338cba', virtualHostClass]}}" style="{{virtualHostStyle}}" hidden="{{virtualHostHidden || false}}" id="{{n}}"><view class="search-bar data-v-f6338cba"><view class="search-input-wrapper data-v-f6338cba"><text class="search-icon data-v-f6338cba">🔍</text><input class="search-input data-v-f6338cba" type="text" placeholder="搜索水果品种、产地..." confirm-type="search" bindconfirm="{{a}}" value="{{b}}" bindinput="{{c}}"/></view></view><scroll-view class="category-scroll data-v-f6338cba" scroll-x enable-flex><view wx:for="{{d}}" wx:for-item="cat" wx:key="b" class="{{['category-item', 'touch-target', 'data-v-f6338cba', cat.c && 'active']}}" bindtap="{{cat.d}}"><text class="data-v-f6338cba">{{cat.a}}</text></view></scroll-view><view wx:if="{{e}}" class="filter-bar data-v-f6338cba"><text class="filter-bar-text data-v-f6338cba">我的货源</text><text class="filter-bar-clear data-v-f6338cba" bindtap="{{f}}">查看全部 ›</text></view><view class="product-list data-v-f6338cba"><view wx:if="{{g}}" class="loading-state data-v-f6338cba"><text class="loading-text data-v-f6338cba">加载中...</text></view><view wx:for="{{h}}" wx:for-item="item" wx:key="q" class="product-card card data-v-f6338cba"><view class="card-header data-v-f6338cba"><view class="card-variety-row data-v-f6338cba"><text class="card-variety data-v-f6338cba">{{item.a}}</text><text wx:if="{{item.b}}" class="urgent-badge data-v-f6338cba">⚡ 急售</text></view><text wx:if="{{item.c}}" class="card-spec data-v-f6338cba">{{item.d}}</text></view><view class="card-body data-v-f6338cba"><view class="card-info data-v-f6338cba"><text class="info-label data-v-f6338cba">产量</text><text class="info-value amount-green data-v-f6338cba">{{item.e}} 斤</text></view><view class="card-info data-v-f6338cba"><text class="info-label data-v-f6338cba">价格</text><text class="info-value amount-gold data-v-f6338cba">{{item.f}} 元/斤</text></view><view class="card-info data-v-f6338cba"><text class="info-label data-v-f6338cba">产地</text><text class="info-value data-v-f6338cba">{{item.g}} {{item.h}}</text></view></view><view class="card-footer data-v-f6338cba"><view class="footer-tags data-v-f6338cba"><text wx:if="{{item.i}}" class="footer-tag data-v-f6338cba">{{item.j}}</text><text wx:if="{{item.k}}" class="footer-tag data-v-f6338cba">{{item.l}}</text></view><text wx:if="{{item.m}}" class="footer-date data-v-f6338cba">{{item.n}} 可发</text><text class="footer-status data-v-f6338cba">{{item.o}}</text></view><view class="card-actions data-v-f6338cba"><view class="offer-btn btn-primary touch-target data-v-f6338cba" catchtap="{{item.p}}"><text class="data-v-f6338cba">接单</text></view></view></view><view wx:if="{{i}}" class="empty-state data-v-f6338cba"><text class="empty-icon data-v-f6338cba">📦</text><text class="empty-text data-v-f6338cba">暂无货源</text><text class="empty-sub data-v-f6338cba">下拉刷新试试</text></view><view wx:if="{{j}}" class="load-more data-v-f6338cba" bindtap="{{l}}"><text class="load-more-text data-v-f6338cba">{{k}}</text></view><view wx:if="{{m}}" class="no-more data-v-f6338cba"><text class="no-more-text data-v-f6338cba">—— 没有更多了 ——</text></view></view></view>